<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/pet_widget_background">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PawPair"
            android:textColor="#E65100"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:orientation="horizontal">
            
            <TextView
                android:id="@+id/widget_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lvl 1"
                android:textColor="#2E7D32"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/widget_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙 0"
                android:textColor="#F57F17"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Left Column: Avatar and Bubble -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#15FF9800"
            android:padding="4dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/widget_pet_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐱"
                android:textSize="38sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/widget_pet_bubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="¡Hola!"
                android:textColor="#4E342E"
                android:textSize="9sp"
                android:textStyle="italic"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Right Column: Info and Bars -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.8"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                
                <TextView
                    android:id="@+id/widget_pet_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mascota"
                    android:textColor="#3E2723"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_pet_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/widget_pet_name"
                    android:text="Jugando 🪁"
                    android:textColor="#5D4037"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Stats Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="2dp">

                <!-- Hunger & Happiness -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="🍗"
                        android:textSize="10sp" />
                        
                    <ProgressBar
                        android:id="@+id/widget_hunger_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="4dp"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#E65100"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="💖"
                        android:textSize="10sp" />
                        
                    <ProgressBar
                        android:id="@+id/widget_happiness_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="4dp"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#E91E63" />
                </LinearLayout>

                <!-- Energy & Cleanliness -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="10sp" />
                        
                    <ProgressBar
                        android:id="@+id/widget_energy_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="4dp"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#FFB300"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="🧼"
                        android:textSize="10sp" />
                        
                    <ProgressBar
                        android:id="@+id/widget_cleanliness_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="4dp"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#03A9F4" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
